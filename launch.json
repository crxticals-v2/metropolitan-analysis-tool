{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🧪 Run All Tests",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "tests/",
                "--tb=short",
                "-v"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "DISCORD_TOKEN": "test_discord_token",
                "MONGO_URI": "mongodb://localhost:27017",
                "GEMINI_API_KEY": "test_gemini_key",
                "WATCHLIST_CHANNEL_ID": "1234567890123456789"
            },
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
